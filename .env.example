# Database
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# LLM Provider (works with Ollama, OpenRouter, OpenAI, Groq, Together, etc.)
# For Ollama (local): LLM_BASE_URL="http://localhost:11434/v1"
# For OpenRouter:     LLM_BASE_URL="https://openrouter.ai/api/v1"
# For OpenAI:         LLM_BASE_URL="https://api.openai.com/v1"
# For Groq:           LLM_BASE_URL="https://api.groq.com/openai/v1"
LLM_BASE_URL="http://localhost:11434/v1"
LLM_API_KEY=""
LLM_MODEL="llama3.1:8b"

# Gmail OAuth (optional - for email parsing)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft/Outlook OAuth (optional - for email parsing)
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"
