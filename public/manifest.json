{
  "name": "Subflo — Subscription Tracker",
  "short_name": "Subflo",
  "description": "AI-powered subscription tracker. Auto-detects recurring payments from email and SMS.",
  "start_url": "/dashboard",
  "display": "standalone",
  "background_color": "#0c0c0e",
  "theme_color": "#635bff",
  "orientation": "portrait",
  "categories": ["finance", "productivity"],
  "icons": [
    { "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" },
    { "src": "/icons/icon-512.png", "sizes": "512x512", "type": "image/png" }
  ],
  "share_target": {
    "action": "/inbox?shared=true",
    "method": "GET",
    "params": {
      "text": "text",
      "title": "title"
    }
  },
  "shortcuts": [
    {
      "name": "Add Subscription",
      "url": "/subscriptions/new",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "SMS Inbox",
      "url": "/inbox",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    }
  ]
}
